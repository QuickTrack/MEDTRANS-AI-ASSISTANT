{
  "name": "medtrans-ai-assistant",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "description": "MedTrans AI Assistant desktop app",
  "author": "MedTrans",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "dist": "bun run build:exe",
    "dist:electron": "electron-builder",
    "build:exe": "bun run build && node scripts/build-exe.mjs"
  },
  "build": {
    "appId": "com.medtrans.ai",
    "productName": "MedTrans AI Assistant",
    "directories": {
      "output": "release",
      "buildResources": "electron"
    },
    "electronDist": "electron-dist",
    "asar": false,
    "files": [
      "electron",
      "package.json",
      ".next/standalone"
    ],
    "extraResources": [
      {
        "from": "vendor/node",
        "to": "node"
      }
    ],
    "win": {
      "target": "portable",
      "icon": "electron/icon.ico"
    },
    "portable": {
      "artifactName": "MedTrans-AI-Assistant.exe"
    }
  },
  "dependencies": {
    "next": "^16.1.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.0.0",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3"
  }
}
